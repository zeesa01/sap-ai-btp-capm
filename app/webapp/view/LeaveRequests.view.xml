<!--
    LeaveRequests.view.xml — Leave Management
    ==========================================
    Shows all leave requests with status-based filtering.
    Managers can Approve / Reject from this view.
    Employees can submit new leave requests.
-->
<mvc:View
    controllerName="hr.fiori.controller.LeaveRequests"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page id="leavePage" title="{i18n>leaveTitle}">

        <headerContent>
            <Button
                text="{i18n>newLeaveRequest}"
                icon="sap-icon://add"
                type="Emphasized"
                press=".onNewLeaveRequest"/>
        </headerContent>

        <content>
            <!-- Status Filter Tabs — clicking a tab filters the table -->
            <IconTabBar
                id="leaveTabBar"
                select=".onTabSelect"
                class="sapUiResponsiveContentPadding">

                <items>
                    <IconTabFilter text="All"      key="all"       icon="sap-icon://list"/>
                    <IconTabFilter text="Pending"  key="Pending"   icon="sap-icon://pending" iconColor="Critical"/>
                    <IconTabFilter text="Approved" key="Approved"  icon="sap-icon://accept"  iconColor="Positive"/>
                    <IconTabFilter text="Rejected" key="Rejected"  icon="sap-icon://decline" iconColor="Negative"/>
                </items>

            </IconTabBar>

            <!-- Leave Requests Table -->
            <Table
                id="leaveTable"
                items="{
                    path: '/LeaveRequests',
                    parameters: {
                        $expand: 'employee,leaveType',
                        $orderby: 'createdAt desc'
                    }
                }"
                growing="true"
                growingThreshold="15"
                noDataText="{i18n>noData}">

                <headerToolbar>
                    <Toolbar>
                        <Title text="Leave Requests" level="H3"/>
                        <ToolbarSpacer/>
                        <Button icon="sap-icon://refresh" type="Transparent" press=".onRefresh"/>
                    </Toolbar>
                </headerToolbar>

                <columns>
                    <Column><Text text="Employee"/></Column>
                    <Column><Text text="Leave Type"/></Column>
                    <Column><Text text="From"/></Column>
                    <Column><Text text="To"/></Column>
                    <Column hAlign="End"><Text text="Days"/></Column>
                    <Column><Text text="Reason"/></Column>
                    <Column><Text text="Status"/></Column>
                    <Column hAlign="Center"><Text text="Actions"/></Column>
                </columns>

                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{employee/firstName} {employee/lastName}"/>
                            <Text text="{leaveType/name}"/>
                            <Text text="{startDate}"/>
                            <Text text="{endDate}"/>
                            <ObjectNumber number="{totalDays}" unit="d"/>
                            <Text text="{reason}" wrapping="false" maxLines="1"/>
                            <ObjectStatus
                                text="{status}"
                                state="{= ${status} === 'Approved' ? 'Success' : ${status} === 'Rejected' ? 'Error' : ${status} === 'Pending' ? 'Warning' : 'None'}"/>
                            <!-- Show approve/reject buttons only for Pending items -->
                            <FlexBox visible="{= ${status} === 'Pending'}">
                                <Button
                                    text="Approve"
                                    type="Accept"
                                    press=".onApproveLeave"
                                    class="sapUiSmallMarginEnd"/>
                                <Button
                                    text="Reject"
                                    type="Reject"
                                    press=".onRejectLeave"/>
                            </FlexBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>

        </content>
    </Page>
</mvc:View>
